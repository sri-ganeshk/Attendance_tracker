# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-2
AWS_PROFILE=default

# ── API (Zappa / Lambda deployment) ──────────────────────────────────────────
ZAPPA_S3_BUCKET=zappa-ppgjh1jcl
ZAPPA_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/api-dev-ZappaLambdaExecutionRole

# ── Shared: base URL of the deployed Flask API (no trailing slash) ────────────
API_BASE_URL=https://your-api-id.execute-api.ap-southeast-2.amazonaws.com/dev

# ── DynamoDB tables (WhatsApp bot) ───────────────────────────────────────────
DYNAMODB_AUTH_TABLE=auth_info_baileys
DYNAMODB_USER_TABLE=user_info

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
